# =====================================================
# CHURCHMANAGER - Redirecionamento Canônico
# =====================================================
# Força HTTPS e remove o "www" via redirecionamento 301
# Versão canônica definida: https://churchmanager.cronosdev.com.br
# =====================================================

Options -Indexes

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ─── 1. Forçar HTTPS ────────────────────────────────
    # Redireciona qualquer requisição HTTP → HTTPS (com ou sem www)
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # ─── 2. Remover "www" ───────────────────────────────
    # Redireciona "https://www.churchmanager.cronosdev.com.br" → "https://churchmanager.cronosdev.com.br"
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # ─── 3. Laravel: Authorization Header ───────────────
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ─── 4. Remover barra final (trailing slash) ────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ─── 5. Front Controller Laravel ────────────────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>

# ─── 6. Segurança básica ────────────────────────────────
# Bloqueia acesso direto a arquivos sensíveis
<FilesMatch "\.(htaccess|htpasswd|env|log|sh|bak|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ─── 7. Cabeçalhos de segurança ─────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── 8. Cache de assets estáticos ───────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
